# IronForge Gym Management — Environment Configuration
# Copy this to .env and fill in your values. NEVER commit .env to version control.

# App metadata
VITE_APP_NAME=IronForge Gym
VITE_APP_VERSION=1.0.0

# Session configuration (in milliseconds)
VITE_SESSION_TIMEOUT_MS=28800000     # 8 hours
VITE_IDLE_TIMEOUT_MS=1800000         # 30 minutes
VITE_ACCESS_TOKEN_TTL_MS=900000      # 15 minutes

# Rate limiting
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_LOCKOUT_BASE_MS=60000           # 1 minute base lockout

# Feature flags
VITE_ENABLE_REGISTRATION=true        # Set false to disable public registration

# For production deployment:
# Set NODE_ENV=production to enable:
#   - HSTS headers
#   - Console.log stripping
#   - Sourcemap disabling
